# Local development environment for the Postgres + TimescaleDB stack.
# Copy to `.env` and edit. `.env` is gitignored; `.env.example` is the only
# committed copy of this file.
#
# Per BUILD_LOG.md decision 1 (Path A), there is no Anthropic API key in this
# project — Claude Code is the runtime. So no AI-related env vars belong here.
#
# Per BUILD_LOG.md decision 6, code is a tool consumed by Claude Code. These
# env vars configure the tool (the local DB) — they are not consumed by any
# Python orchestrator.

# Postgres + TimescaleDB
POSTGRES_DB=equity_research
POSTGRES_USER=equity_research_admin
POSTGRES_PASSWORD=change-me-locally
POSTGRES_PORT=5432

# Connection string for tools (psql, MCP server, etc.):
# postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}

# SEC EDGAR — required per fair-access policy. Format: 'Project Name your@email'
EDGAR_USER_AGENT=

# FRED API key — free, register at https://fredaccountmanager.research.stlouisfed.org/apikey
FRED_API_KEY=

# Nasdaq Data Link (Sharadar Core US Fundamentals) — OPTIONAL.
# Free tier provides only MRY (restated, NOT PIT) + 2 fiscal years + sample
# tickers — strictly worse than EDGAR XBRL on every dimension. Paid SF1
# subscription (~$70-100/mo) unlocks ARY/ARQ (PIT) + full history + full
# universe. v0.1 fundamentals MCP runs EDGAR-only; this key is a no-op
# until/unless the paid tier is activated. Register at https://data.nasdaq.com
NDL_API_KEY=

# Market data MCP (operator decision 2026-04-30: Polygon promoted from v0.5+ to v0.1
# default for "high quality live market data"). Yfinance remains the fallback.
# Plan: Stocks Starter ($29/mo) is the minimum tier for real-time consolidated SIP
# quotes; the free tier returns 15-min-delayed data via the same endpoint shape.
# Register at https://polygon.io/dashboard/api-keys
MARKET_DATA_PROVIDER=polygon
POLYGON_API_KEY=

# Massive MCP — real-time stocks feed for the /micro intraday day-trading helper
# (≤1-day horizon). Separate from MARKET_DATA_PROVIDER above (that is the slow
# layer's daily OHLCV/news feed). Massive's wire protocol is Polygon-compatible.
# WS_URL default is the real-time feed; use wss://delayed.massive.com for delayed.
# Register at https://massive.com
MASSIVE_API_KEY=
MASSIVE_WS_URL=wss://socket.massive.com
MASSIVE_REST_URL=https://api.massive.com

# Broker MCP (Schwab default). Read-only positions endpoint per Section 7 Q5.
# Register an app at https://developer.schwab.com to obtain client credentials.
# After running the operator-interactive authorize flow (see
# src/mcp/broker_mcp/README.md), the access/refresh tokens are populated below
# and refreshed automatically on each MCP tool call.
BROKER_PROVIDER=schwab
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_ACCESS_TOKEN=
SCHWAB_REFRESH_TOKEN=
SCHWAB_TOKEN_EXPIRES_AT=

# HMAC keys (4 distinct scopes — separate rotation lifetimes)
# All use canonical_payload from audit_trail.hmac_verify
# (sort_keys=True, separators=(',',':'), ensure_ascii=False).
# Never share keys across scopes; each is independently revocable.
# Generate each: python -c "import secrets; print(secrets.token_urlsafe(32))"

# Audit chain — execution_recommendations + audit_provenance row signing
# (P3 emitter, P7 emitter). Per v3 §5.2 + §7 Q4 launch gate.
AUDIT_HMAC_KEY=

# Peak-pain catalog — peak_pain_archetypes row signing
# (catalog write/verify). Per v3 §6.2 + migration 016.
PEAK_PAIN_HMAC_KEY=

# Premortem — premortem row signing
# (premortem_scheduler.recorder). Per v3 §4.5 Q4 + migration 016.
PREMORTEM_HMAC_SECRET=

# Watchlist — thesis_pillars_original + scenario_A_base_projections signing
# (watchlist HMAC producer + anchor_drift verifier). Per v3 §2.2 + migration 007.
WATCHLIST_HMAC_SECRET=

# Push-alert email channel — `src/alert_channels/email_sender.py`.
# Per v3 Section 5.3 / Section 7 PB#4 / Phase 4 Q9. M-3 alerts only.
# For Gmail: use an app password from https://myaccount.google.com/apppasswords
# (account password is rejected by SMTP). All six vars required;
# SmtpConfig.from_env() raises if any is missing.
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_SENDER=
ALERT_SMTP_RECIPIENT=
ALERT_SMTP_USE_TLS=1

# Macro-stack MCP (BLS / BEA / Census Bureau)
# All three are free with registration:
#   BLS:    https://data.bls.gov/registrationEngine/
#   BEA:    https://apps.bea.gov/API/signup/
#   Census: https://api.census.gov/data/key_signup.html
BLS_API_KEY=
BEA_API_KEY=
CENSUS_API_KEY=
